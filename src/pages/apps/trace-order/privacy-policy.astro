---
import BaseLayout from '../../../layouts/BaseLayout.astro';
const appName = "Trace Order";
const lastUpdated = "March 2025";
const contactEmail = "hello@wiplabs.app";
---

<BaseLayout title={`Privacy Policy — ${appName}`} description={`Privacy Policy for ${appName} by WIPLabs.`}>
  <style>
    .policy-page { padding: 4rem 0; max-width: 720px; }
    .policy-page h1 { font-size: 2rem; font-weight: 800; margin-bottom: 0.5rem; }
    .meta { color: var(--text-muted); font-size: 0.875rem; margin-bottom: 3rem; }
    .policy-page h2 { font-size: 1.15rem; font-weight: 700; margin: 2.5rem 0 0.75rem; color: var(--text); }
    .policy-page p { color: var(--text-muted); line-height: 1.8; margin-bottom: 1rem; }
    .policy-page ul { color: var(--text-muted); padding-left: 1.5rem; line-height: 1.8; margin-bottom: 1rem; }
    .policy-page a { color: var(--accent); }
    .back-link { display: inline-flex; align-items: center; gap: 0.4rem; color: var(--text-muted); font-size: 0.875rem; margin-bottom: 2rem; transition: color 0.2s; }
    .back-link:hover { color: var(--text); }
    hr { border: none; border-top: 1px solid var(--border); margin: 2rem 0; }
    .highlight-box {
      background: var(--accent-dim);
      border: 1px solid var(--accent);
      border-radius: 10px;
      padding: 1rem 1.25rem;
      color: var(--accent);
      font-size: 0.95rem;
      margin: 1.5rem 0;
      display: flex;
      gap: 0.5rem;
      align-items: center;
    }
  </style>

  <div class="container">
    <div class="policy-page">
      <a href="/apps/trace-order" class="back-link">← Back to {appName}</a>
      <h1>Privacy Policy</h1>
      <p class="meta">{appName} · WIPLabs · Last updated: {lastUpdated}</p>

      <hr />

      <div class="highlight-box">
        <span>🔒</span>
        <span>Trace Order does not collect, store, or share any personal data from users or devices.</span>
      </div>

      <h2>1. About Trace Order</h2>
      <p>
        Trace Order is a simple order tracking and front-end accounting app designed for small
        businesses of any size. It allows business owners and teams to create, manage, and track
        customer orders — including order status, delivery tracking, and basic accounting operations.
        The app is available in Turkish, English, and Spanish.
      </p>

      <h2>2. Information We Do Not Collect</h2>
      <p>
        We do not collect, store, transmit, or share any personal data. This includes but is not limited to:
      </p>
      <ul>
        <li>Personal identification information</li>
        <li>Device identifiers or hardware information</li>
        <li>Location data</li>
        <li>Usage analytics or behavioral data</li>
        <li>Contacts, camera, or any other device permissions</li>
      </ul>

      <h2>3. How the App Works</h2>
      <ul>
        <li>All data you enter — orders, customers, notes — is stored locally on your device only.</li>
        <li>Nothing is transmitted to external servers or third parties.</li>
        <li>If you delete the app, all data is permanently removed from your device.</li>
        <li>We have no access to your data at any point.</li>
      </ul>

      <h2>4. Third-Party Services</h2>
      <p>
        Trace Order does not integrate with any third-party analytics, advertising, or tracking services.
      </p>

      <h2>5. Data Security</h2>
      <p>
        Since we do not collect or transmit any data, there are no security risks related to
        data storage or processing on our end. Your data stays entirely on your device.
      </p>

      <h2>6. Children's Privacy</h2>
      <p>
        Trace Order is rated 4+ and is suitable for all ages. Since we do not collect
        any personal data from any users, there are no special privacy concerns related
        to younger users.
      </p>

      <h2>7. Changes to This Policy</h2>
      <p>
        We may update this Privacy Policy from time to time. Any changes will be reflected
        by updating the "Last updated" date above.
      </p>

      <h2>8. Contact Us</h2>
      <p>
        If you have any questions about this Privacy Policy, please contact us at:
        <a href={`mailto:${contactEmail}`}>{contactEmail}</a>
      </p>
    </div>
  </div>
</BaseLayout>