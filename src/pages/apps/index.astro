---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { apps } from '../../data/apps.js';
---

<BaseLayout title="Apps" description="All apps published by WIPLabs.">
  <style>
    .page-header {
      padding: 4rem 0 2rem;
      border-bottom: 1px solid var(--border);
      margin-bottom: 3rem;
    }

    .page-header h1 {
      font-size: clamp(2rem, 5vw, 3.5rem);
      font-weight: 800;
      letter-spacing: -0.03em;
      margin-bottom: 0.75rem;
    }

    .page-header p {
      color: var(--text-muted);
      font-size: 1rem;
      max-width: 480px;
    }

    .apps-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
      gap: 1.5rem;
      padding-bottom: 4rem;
    }

    .app-card {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 2rem;
      transition: border-color 0.2s, transform 0.2s;
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .app-card:hover {
      border-color: var(--accent);
      transform: translateY(-3px);
    }

    .app-card-top {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
    }

    .app-icon {
      width: 56px;
      height: 56px;
      border-radius: 14px;
      background: var(--bg-hover);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.6rem;
      border: 1px solid var(--border);
    }

    .app-card h2 {
      font-size: 1.15rem;
      font-weight: 700;
    }

    .app-card .tagline {
      font-size: 0.875rem;
      color: var(--text-muted);
      line-height: 1.6;
    }

    .app-meta {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-top: auto;
      padding-top: 1rem;
      border-top: 1px solid var(--border);
    }

    .platform-tags {
      display: flex;
      gap: 0.4rem;
    }

    .platform-tag {
      font-size: 0.72rem;
      font-weight: 600;
      font-family: 'Syne', sans-serif;
      padding: 0.2rem 0.5rem;
      border-radius: 4px;
      background: var(--bg-hover);
      color: var(--text-muted);
      border: 1px solid var(--border);
    }

    .app-links {
      display: flex;
      gap: 0.5rem;
    }

    .app-link {
      font-size: 0.8rem;
      font-weight: 600;
      color: var(--accent);
      font-family: 'Syne', sans-serif;
    }
  </style>

  <div class="container">
    <div class="page-header">
      <h1>All <span class="accent">Apps</span></h1>
      <p>Every app built and published by WIPLabs. More on the way.</p>
    </div>

    <div class="apps-grid">
      {apps.map((app) => (
        <div class="app-card">
          <div class="app-card-top">
            <div class="app-icon">
              {app.appIcon
                ? <img src={app.appIcon} alt={app.name} style="width:100%;height:100%;border-radius:10px;object-fit:cover;" />
                : <span>📦</span>
              }
            </div>
            <span class={`badge ${app.status}`}>
              {app.status === 'live' ? 'Live' : app.status === 'wip' ? 'WIP' : 'Soon'}
            </span>
          </div>
          <h2>{app.name}</h2>
          <p class="tagline">{app.description}</p>
          <div class="app-meta">
            <div class="platform-tags">
              {app.platform.map(p => <span class="platform-tag">{p}</span>)}
            </div>
            <div class="app-links">
              <a href={`/apps/${app.slug}`} class="app-link">Details →</a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</BaseLayout>
